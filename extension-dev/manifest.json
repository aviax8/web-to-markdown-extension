{
  "manifest_version": 3,
  "name": "__MSG_extension_name__",
  "version": "1.2.0",
  "description": "__MSG_extension_description__",
  "default_locale": "en",
  "author": "aviax8",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48-red.png",
    "128": "icons/icon128-red.png"
  },
  "permissions": ["clipboardWrite", "storage", "contextMenus"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "host_permissions": [],
  "background": {
    "scripts": [
      "i18n.js",
      "background.js"
    ]
  },
  "web_accessible_resources": [
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "i18n.js",
        "settings.js",
        "content.js",
        "turndown.js",
        "turndown-plugin-gfm.js",
        "turndown-plugin-ext.js"
      ],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "web-to-markdown-dev@aviax8.dev",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
